                "unit": 1,
                "options": {
                  "style": "decimal"
                }
              }
            },
            {
              "columnMatch": "% of Compliant Device",
              "formatter": 0,
              "numberFormat": {
                "unit": 1,
                "options": {
                  "style": "decimal"
                }
              }
            },
            {
              "columnMatch": "% of Trusted Device",
              "formatter": 0,
              "numberFormat": {
                "unit": 1,
                "options": {
